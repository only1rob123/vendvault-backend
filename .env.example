PORT=3001
JWT_SECRET=vendvault-super-secret-change-in-production
NODE_ENV=development
DB_PATH=./vendvault.db

# Email Auto-Import (optional)
# Set these to enable automatic CSV import from email inbox
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_TLS=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_COMPANY_ID=your-company-uuid-here
EMAIL_POLL_INTERVAL_MINS=15
